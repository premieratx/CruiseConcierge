{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does an Austin party boat cost in 2026?", "acceptedAnswer": { "@type": "Answer", "text": "Two pricing models. (1) ATX Disco Cruise per-person tickets: $85 (Saturday 3:30–7:30 PM sunset), $95 (Friday 12–4 PM), $105 (Saturday 11 AM–3 PM peak). All-inclusive — tax, 20% gratuity, DJ, photographer, floats included. (2) Private charter hourly rates starting at $200/hour (Day Tripper, 14 guests), $225/hour (Meeseeks/Irony, 15–30 guests), $250/hour (Clever Girl flagship, 31–75 guests). 4-hour minimum Fri–Sun, 3-hour minimum Mon–Thu. Weekend rates higher than weekday." } },
    { "@type": "Question", "name": "What is included in the ATX Disco Cruise all-inclusive price?", "acceptedAnswer": { "@type": "Answer", "text": "Every ATX Disco Cruise ticket includes: 4-hour cruise, USCG-certified captain + crew, professional DJ, professional photographer (high-res digital delivery 2–3 weeks later), 14 disco balls, giant lily pad floats, personal cooler + private bin per group, cups, koozies, champagne bubbles, 8.25% Texas sales tax, and 20% gratuity. You bring only drinks (BYOB, cans/plastic only)." } },
    { "@type": "Question", "name": "What does a private Austin party boat charter include?", "acceptedAnswer": { "@type": "Answer", "text": "Standard private charter includes: USCG-licensed captain, premium marine Bluetooth audio, coolers (always BYOB), sun and shade seating, on-board restrooms, stops at party coves. Optional Essentials and Ultimate add-on packages add DJ, photographer, floats, decorations, and catering coordination. Fuel, tax, and gratuity are additional on private charters." } },
    { "@type": "Question", "name": "Are there hidden fees on Austin party boats?", "acceptedAnswer": { "@type": "Answer", "text": "Not at Premier Party Cruises. Disco Cruise tickets include tax + 20% gratuity — the price you see is the price you pay. Private charters show fuel, tax, and gratuity as clearly itemized line items at checkout — no surprise add-ons. Crew surcharge applies for 51–75 guest groups on Clever Girl and is disclosed upfront." } },
    { "@type": "Question", "name": "Is Austin party boat pricing cheaper on weekdays?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — weekday private charters (Mon–Thu) run lower hourly rates AND have a 3-hour minimum instead of 4-hour, which can save $400–$600 vs weekend. ATX Disco Cruise is weekends only (Fri/Sat) so no weekday option. Mon–Thu private charters on any boat are the cheapest way to get on Lake Travis." } },
    { "@type": "Question", "name": "How does Austin party boat pricing compare to other cities?", "acceptedAnswer": { "@type": "Answer", "text": "Austin is 20–40% cheaper than Miami, Lake Tahoe, or Lake of the Ozarks for comparable all-inclusive party boats. $85/person for 4 hours with DJ + photographer included is unheard of in Miami ($150–$225/person equivalent) or Tahoe ($175/person). The Austin market is the national price leader for multi-group party cruises." } },
    { "@type": "Question", "name": "Do you offer group discounts on Austin party boats?", "acceptedAnswer": { "@type": "Answer", "text": "Disco Cruise: no group discounts — pricing is already tuned for maximum value. Private charters: group of 51–75 on Clever Girl has a crew surcharge (not a discount), disclosed upfront. Real savings come from picking the right slot (weekday > weekend, sunset > peak) and right boat size." } }
  ]
}
