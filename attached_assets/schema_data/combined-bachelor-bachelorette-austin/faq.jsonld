      "@type": "Question",
      "name": "What is a combined bachelor/bachelorette party?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "One celebration for both friend groups\u2014shared fun with everyone together."
      }
    },
    {
      "@type": "Question",
      "name": "Should we book Private or join the Disco Cruise?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Under ~30 guests: Disco is typically best value. 30+ or full control: Private."
      }
    },
    {
      "@type": "Question",
