{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What's the best way to get from downtown Austin to the Lake Travis marina?", "acceptedAnswer": { "@type": "Answer", "text": "For groups of 8+, book a party bus or limo — keeps the group together, no DD required, and the ride becomes part of the party. For groups of 4–7, Uber XL or two Uber XLs. For groups of 1–3, a single Uber. Anderson Mill Marina is 13993 FM 2769, Leander TX — roughly 30–35 minutes from downtown Austin via the 183-A toll." } },
    { "@type": "Question", "name": "How much does an Austin party bus cost?", "acceptedAnswer": { "@type": "Answer", "text": "Austin party bus pricing ranges $150–$250/hour with a 3–4 hour minimum — expect $600–$1,000 for a round-trip Lake Travis day. Limos and sprinter vans run $120–$180/hour. Book 2–3 weeks out for peak-season Saturdays. Premier Party Cruises can recommend vetted Austin party bus vendors during the quote process." } },
    { "@type": "Question", "name": "How many people fit on an Austin party bus?", "acceptedAnswer": { "@type": "Answer", "text": "Sprinter vans seat 12–14. Mid-size party buses seat 20–24. Large party buses seat 30–40. For a 50-person Lake Travis group, two 25-person party buses is more comfortable than one 50-person coach on the winding roads to Anderson Mill Marina." } },
    { "@type": "Question", "name": "Can a party bus pick us up at an Austin Airbnb and drop us at the marina?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — this is the default setup. Pickup at your Austin Airbnb or hotel, drop-off at Anderson Mill Marina 15–20 min before your cruise departure, pickup at end of cruise, return downtown. Some groups have the party bus wait at the marina for the full 4-hour cruise (add 4 hours of hourly rate)." } },
    { "@type": "Question", "name": "Does Premier Party Cruises provide the party bus?", "acceptedAnswer": { "@type": "Answer", "text": "No — we're a boat operator, not a ground transport company. But we partner with vetted Austin party bus and limo vendors and can connect you during your quote process. Party On Delivery (sister company) coordinates drink delivery to the marina so the party bus doesn't need to stop at a liquor store." } },
    { "@type": "Question", "name": "Do we need to tip the party bus driver?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — 18–20% gratuity is standard for Austin party bus and limo drivers, usually added at booking or paid in cash at drop-off. Confirm with your vendor whether it's included in the quote or added after." } }
  ]
}
