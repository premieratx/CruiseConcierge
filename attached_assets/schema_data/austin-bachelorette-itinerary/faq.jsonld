{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the best 3-day Austin bachelorette party itinerary?", "acceptedAnswer": { "@type": "Answer", "text": "Friday: arrival + Rainey Street bar crawl + downtown dinner (Uchi, Launderette, Perla's). Saturday (the anchor): Lake Travis party boat on the ATX Disco Cruise Saturday 11 AM–3 PM peak slot ($105/person all-inclusive — DJ, photographer, 14 disco balls, floats, 4 hours), then shower + change downtown, 7:30 PM marquee dinner, closing night out. Sunday: South Congress brunch + shopping + send-off." } },
    { "@type": "Question", "name": "How much does an Austin bachelorette weekend cost per person?", "acceptedAnswer": { "@type": "Answer", "text": "Budget $500–$900 per person for a 3-day Austin bachelorette weekend. Breakdown: ATX Disco Cruise ticket $85–$105, Airbnb split $150–$250, dinners $175–$300, nightlife $100–$200, ground transport $50–$100. Austin is 30–40% cheaper than Nashville or Miami for comparable experiences." } },
    { "@type": "Question", "name": "When should I book the Lake Travis party boat for a bachelorette party?", "acceptedAnswer": { "@type": "Answer", "text": "6–8 weeks before peak season (April–October) Saturdays. The Saturday 11 AM–3 PM Disco Cruise slot sells out first. Book the boat FIRST — it is the anchor — then stack the rest of the weekend around it (Airbnb, Saturday dinner, brunch)." } },
    { "@type": "Question", "name": "Best Austin restaurants for bachelorette dinner?", "acceptedAnswer": { "@type": "Answer", "text": "Top Austin bachelorette dinner picks: Uchi (sushi omakase), Launderette (chic East Austin), Franklin Barbecue (book catering ahead), Terry Black's (no-line BBQ), Emmer & Rye, Dai Due, Kemuri Tatsu-Ya (Japanese-Texan fusion). Book the Saturday marquee dinner 3–4 weeks out." } },
    { "@type": "Question", "name": "Should we stay downtown, East Austin, or on the lake for a bachelorette weekend?", "acceptedAnswer": { "@type": "Answer", "text": "Downtown, East Austin, or South Congress Airbnb for groups of 8+. Rainey/Downtown hotels (Fairmont, JW Marriott, Hotel Van Zandt, Austin Proper) for smaller groups. Avoid Leander/Cedar Park — you'll miss the nightlife that anchors the weekend." } },
    { "@type": "Question", "name": "Can we do a private boat instead of the ATX Disco Cruise?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — private Clever Girl charters are available year-round from $250/hour with a 4-hour minimum. Private charters are best for groups of 25+ who want exclusive access, custom music, and schedule flexibility. For groups of 5–20, the ATX Disco Cruise delivers more party energy at lower total cost." } },
    { "@type": "Question", "name": "What should my bachelorette group wear on the Lake Travis party boat?", "acceptedAnswer": { "@type": "Answer", "text": "Matching swimsuits + cover-ups, bride sash, coordinating sunglasses, and cute sandals are the Austin bachelorette uniform. Bring a change of clothes for after. Themes are encouraged — disco, Western, white-for-bride, neon. Sunscreen must be cream/lotion only (no spray — makes the deck slippery)." } }
  ]
}
