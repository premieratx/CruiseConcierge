{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the best 3-day Austin bachelor party itinerary?", "acceptedAnswer": { "@type": "Answer", "text": "Friday: arrival + 6th Street/Rainey Street kickoff + steakhouse dinner. Saturday (the anchor): Lake Travis party boat on the ATX Disco Cruise (Saturday 11 AM–3 PM peak slot, $105/person all-inclusive) or a private Clever Girl charter, followed by marquee dinner (Franklin, Terry Black's, Uchi) and closing night out. Sunday: optional early tee time, BBQ pilgrimage, and send-off." } },
    { "@type": "Question", "name": "How much does an Austin bachelor weekend cost per person?", "acceptedAnswer": { "@type": "Answer", "text": "Budget $600–$1,100 per person for a 3-day Austin bachelor weekend. Breakdown: ATX Disco Cruise ticket $85–$105, Airbnb split $150–$250, dinners $200–$350, nightlife $150–$250, ground transport $50–$100. Austin runs significantly cheaper than Vegas, Miami, or Nashville for comparable experiences." } },
    { "@type": "Question", "name": "When should I book the Lake Travis party boat for a bachelor party?", "acceptedAnswer": { "@type": "Answer", "text": "6–8 weeks before peak season (March–October) Saturdays. The Saturday 11 AM–3 PM Disco Cruise slot is the first to sell out. For private Clever Girl charters on peak weekends, 8–12 weeks ahead is safer. Book the boat FIRST, then stack the rest of the weekend (steakhouse, golf, Airbnb) around it." } },
    { "@type": "Question", "name": "Best Austin steakhouses for bachelor parties?", "acceptedAnswer": { "@type": "Answer", "text": "Top picks: Jeffrey's (old-school Austin institution), Vince Young Steakhouse (power dinner vibe), Uchi (world-class sushi omakase), Hestia (live-fire dining), Red Ash (Italian steakhouse), Nickel City (no-frills cocktails + food). Book 3–4 weeks out for Saturday 7:30 PM." } },
    { "@type": "Question", "name": "Should we stay downtown or on the lake for an Austin bachelor party?", "acceptedAnswer": { "@type": "Answer", "text": "Stay downtown or East Austin. You need walking access to 6th Street, Rainey Street, and East Cesar Chavez nightlife — that's where the weekend happens outside of the Saturday lake day. Leander/Cedar Park Airbnbs near the marina isolate you from everything else and force expensive Ubers." } },
    { "@type": "Question", "name": "Can we combine our Austin bachelor party with a bachelorette party?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — the ATX Disco Cruise is built for combined bach parties. Both groups buy individual tickets, board the same boat, and join 50–100 other bach party guests. No coordination required between groups ahead of time. Many couples do the cruise Saturday and split up for separate night activities." } },
    { "@type": "Question", "name": "What's the best golf for an Austin bachelor weekend?", "acceptedAnswer": { "@type": "Answer", "text": "Grey Rock Golf Club (public, 15 min from downtown, great condition), Barton Creek Resort (4 championship courses, resort amenities), Roy Kizer (public, river views, affordable), Spanish Oaks (private, connection needed). Morning tee times pair with Saturday lake day without killing weekend energy." } }
  ]
}
