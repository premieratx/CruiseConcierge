{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How do I plan an Austin bachelor or bachelorette weekend around a Lake Travis party boat?", "acceptedAnswer": { "@type": "Answer", "text": "Book the Lake Travis party boat FIRST — it's the anchor event. Saturday 11 AM–3 PM ATX Disco Cruise or a private Clever Girl charter. Then stack: Airbnb/hotel downtown or East Austin, Saturday marquee dinner (book 3–4 weeks ahead), Friday night kickoff on Rainey/6th, Sunday brunch + shopping. Don't reverse the order — restaurants rebook, but peak Saturday lake slots don't." } },
    { "@type": "Question", "name": "How far in advance should I plan a Lake Travis party boat trip?", "acceptedAnswer": { "@type": "Answer", "text": "6–8 weeks for peak-season (April–October) Saturdays. 8–12 weeks for SXSW, F1, Austin City Limits weekends. 2–4 weeks is workable for weekday private charters off-season (Nov–Feb). Book the boat first, then flights and Airbnb." } },
    { "@type": "Question", "name": "Where should we stay for an Austin trip that includes Lake Travis?", "acceptedAnswer": { "@type": "Answer", "text": "Downtown Austin, East Austin, or South Congress Airbnb/hotel for 85% of groups — the marina is a 30–35 minute Uber XL away, and you need downtown for nightlife. Only stay at the lake (Lakeway, Volente) if your group wants quiet weekend + zero downtown nightlife. The lake is for the daytime cruise, not the weekend base." } },
    { "@type": "Question", "name": "How do we get from downtown Austin to Anderson Mill Marina?", "acceptedAnswer": { "@type": "Answer", "text": "Uber XL (30–35 min, ~$55–$80 each way for a full van), party bus or limo (best for groups of 8+, book 2 weeks ahead), or self-drive with designated driver. Anderson Mill Marina has free on-site parking. Address: 13993 FM 2769, Leander TX 78641." } },
    { "@type": "Question", "name": "Do we need to rent a car in Austin?", "acceptedAnswer": { "@type": "Answer", "text": "No. Austin-Bergstrom Airport (AUS) → downtown Ubers are 15–20 minutes. Downtown to marina is another Uber XL. Rental cars add hassle (parking, DD assignment) without adding flexibility for a 2–3 day bachelor/bachelorette weekend anchored by the lake day." } },
    { "@type": "Question", "name": "What months is Lake Travis party season?", "acceptedAnswer": { "@type": "Answer", "text": "ATX Disco Cruise runs March through October (weekends only). Private charters run year-round, every day. Peak weather and party atmosphere are late April through early September. November–February private charters are quieter, cheaper, and the lake is gorgeous — great for smaller intimate groups." } }
  ]
}
