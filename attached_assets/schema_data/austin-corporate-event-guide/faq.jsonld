{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Can I host a corporate event on a Lake Travis party boat?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — private Lake Travis charters are a top Austin corporate event venue. Year-round availability, every day of the week, groups of 14–75 on four vessels (Day Tripper, Meeseeks, The Irony, Clever Girl). Licensed USCG captain, premium sound, on-board restrooms, catering coordination available via optional Ultimate package. Use Clever Girl for company-wide outings, Meeseeks/Irony for team dinners, Day Tripper for exec retreats." } },
    { "@type": "Question", "name": "What's the best Austin corporate team building venue on Lake Travis?", "acceptedAnswer": { "@type": "Answer", "text": "Private charter on Clever Girl (up to 75) or The Irony (up to 30) is the top Austin corporate team building venue because it combines an off-site experience (forced shared activity, no offices, no phones), easy catering, and memorable Lake Travis scenery. Starting at $200–$250/hour with 4-hour minimum on weekends, 3-hour minimum Mon–Thu." } },
    { "@type": "Question", "name": "Can I get invoiced or use a corporate card for an Austin party boat booking?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — Premier Party Cruises accepts corporate cards and can issue W-9, COI (Certificate of Insurance), and formal invoices for AP. Many Austin tech companies (Indeed, Dell, Oracle, Atlassian, Bumble alumni) book annual team events with us. Request corporate billing during the quote process." } },
    { "@type": "Question", "name": "Do you offer branded corporate events on your boats?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — private charters support branded banners, step-and-repeat photo backdrops, custom playlists, and branded koozies/swag. Ultimate package adds branded decor coordination. Boat decks are ideal for group photos and LinkedIn content." } },
    { "@type": "Question", "name": "What's the alcohol policy for corporate events on Lake Travis?", "acceptedAnswer": { "@type": "Answer", "text": "All boats are BYOB. Many companies partner with Party On Delivery (sister company) to handle drinks, ice, and set-up — zero logistics for the organizer. Corporate events can be fully alcohol-free, wine/champagne only, or full bar — your call. No corkage, no minimum spend." } },
    { "@type": "Question", "name": "Is a Lake Travis party boat appropriate for client entertainment?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — private charters on Day Tripper (up to 14) or Meeseeks (up to 25) are ideal for Austin client entertainment. Controlled environment (no public guests), picturesque Lake Travis backdrop, licensed captain handles all logistics so you focus on the client. Pairs well with a Saturday lake day followed by a downtown steakhouse dinner." } },
    { "@type": "Question", "name": "How far in advance should we book a corporate event on Lake Travis?", "acceptedAnswer": { "@type": "Answer", "text": "4–8 weeks ahead for weekday corporate charters, 8–12 weeks ahead for Saturday charters in peak season (April–October). SXSW, F1 weekend, and Austin City Limits weekends require 3–4 month lead time. Winter corporate events (Nov–Feb) have much more flexibility — often bookable 2–3 weeks out." } }
  ]
}
