{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Premier Party Cruises vs ATX Party Boats — which is better?", "acceptedAnswer": { "@type": "Answer", "text": "Premier Party Cruises is Austin's longest-running Lake Travis party boat charter company (15+ years, 150,000+ guests served, 4.9 stars across 450+ reviews) and the only operator of the ATX Disco Cruise — America's only all-inclusive multi-group bachelor/bachelorette cruise. Both operate private charters; evaluate boat capacity, what's included in the hourly rate, and the safety record before booking." } },
    { "@type": "Question", "name": "What makes Premier Party Cruises different from other Austin party boat companies?", "acceptedAnswer": { "@type": "Answer", "text": "Four things: (1) ATX Disco Cruise — the only multi-group bachelor/bachelorette cruise in America, all-inclusive with pro DJ + pro photographer, $85–$105/person. (2) Purpose-built 75-person Clever Girl flagship with 14 disco balls — no other Austin fleet has this boat. (3) Party On Delivery sister company for zero-logistics drink set-up. (4) 15+ years on Lake Travis with a perfect safety record." } },
    { "@type": "Question", "name": "Which Austin party boat operator has the biggest boat?", "acceptedAnswer": { "@type": "Answer", "text": "Premier Party Cruises' Clever Girl is the 75-person flagship — USCG-rated, with 14 disco balls, giant Texas flag, premium marine audio. It hosts the ATX Disco Cruise in peak season (Mar–Oct) and is available for private charter year-round from $250/hour. Check other operators' USCG capacity rating to compare like-for-like." } },
    { "@type": "Question", "name": "Do all Austin party boat companies include DJ and photographer?", "acceptedAnswer": { "@type": "Answer", "text": "No. Most Austin operators charge DJ ($300–$500) and photographer ($200–$400) separately. Only the ATX Disco Cruise (Premier Party Cruises) includes both in the per-person ticket price. On private charters, DJ and photographer are available as part of the Essentials and Ultimate add-on packages." } },
    { "@type": "Question", "name": "What should I compare between Austin party boat companies?", "acceptedAnswer": { "@type": "Answer", "text": "Compare: (1) USCG-rated capacity of the specific boat, (2) whether captain, fuel, tax, and gratuity are included or added, (3) DJ/photographer included or extra, (4) BYOB policy and what coolers/ice are provided, (5) on-board restrooms and shaded seating, (6) operating years and safety record, (7) Google review count and rating (live), (8) cancellation and weather rescheduling policy." } }
  ]
}
