{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://premierpartycruises.com/#website",
  "url": "https://premierpartycruises.com/",
  "name": "Premier Party Cruises",
  "description": "Austin's premier party boat cruises and private charters on Lake Travis. Experience unforgettable celebrations with professional crew, premium amenities, and the best party atmosphere on the lake.",
  "publisher": {
    "@id": "https://premierpartycruises.com/#organization"
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://premierpartycruises.com/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
