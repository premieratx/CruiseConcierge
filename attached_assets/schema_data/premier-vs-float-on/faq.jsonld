{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Premier Party Cruises vs Float On — which Austin party boat is better?", "acceptedAnswer": { "@type": "Answer", "text": "Different products. Float On operates mostly on Lady Bird Lake (downtown, slow, no-wake, limited music, shorter runs) and does private rentals. Premier Party Cruises operates on Lake Travis (open water, deeper, full music, long runs) and specializes in the all-inclusive ATX Disco Cruise for bachelor/bachelorette parties plus private charters on the 75-person Clever Girl flagship. For bach parties or energetic groups, Premier on Lake Travis is the category leader." } },
    { "@type": "Question", "name": "Is Lake Travis or Lady Bird Lake better for a party boat?", "acceptedAnswer": { "@type": "Answer", "text": "Lake Travis for the party — open water, swimming coves, deeper water, and no no-wake restrictions so you can run real marine audio and the boat actually moves. Lady Bird Lake (downtown) is no-wake only, closer to the city but slower and quieter. Lake Travis is 30–40 minutes from downtown Austin via Uber XL or party bus." } },
    { "@type": "Question", "name": "Does Float On have the ATX Disco Cruise?", "acceptedAnswer": { "@type": "Answer", "text": "No. The ATX Disco Cruise is exclusively operated by Premier Party Cruises. It's the only all-inclusive multi-group bachelor/bachelorette party cruise in America — Fri/Sat slots, per-person ticketing, 14 disco balls on the 75-person Clever Girl, pro DJ and photographer included. No other Austin operator runs this product." } },
    { "@type": "Question", "name": "How does pricing compare between Premier and Float On?", "acceptedAnswer": { "@type": "Answer", "text": "Premier Party Cruises private charter pricing starts at $200/hour (Day Tripper, 14 guests) with published hourly rates on every boat size up to the 75-person Clever Girl at $250/hour. The ATX Disco Cruise is a flat per-person ticket: $85–$105 all-inclusive with tax + 20% gratuity baked in. Float On pricing varies by product; compare on an apples-to-apples basis (boat size, length of cruise, what's included)." } },
    { "@type": "Question", "name": "Which Austin party boat company has the best safety record?", "acceptedAnswer": { "@type": "Answer", "text": "Premier Party Cruises — 15+ years operating on Lake Travis, 150,000+ guests served, perfect safety record, all USCG-licensed captains. Safety record is published on the /safety page with the underlying operational data." } },
    { "@type": "Question", "name": "Which company has more reviews — Premier or Float On?", "acceptedAnswer": { "@type": "Answer", "text": "Premier Party Cruises has 450+ Google reviews at a 4.9-star average rating. Check both companies' live Google review counts and ratings before booking — always rely on current data, not outdated third-party roundups." } }
  ]
}
