{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the ATX Disco Cruise?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A shared 4-hour party boat for bachelor/bachelorette groups with pro DJ and photographer, BYOB, floats, and multi-group energy."
      }
    },
    {
      "@type": "Question",
      "name": "When does it run?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Fridays 12–4 PM and Saturdays 11–3 PM or 3:30–7:30 PM from March to October."
      }
    },
    {
      "@type": "Question",
      "name": "How much are tickets?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Friday 12-4pm: $95/person. Saturday 11am-3pm: $105/person. Saturday 3:30-7:30pm: $85/person."
      }
    },
    {
      "@type": "Question",
      "name": "What happens in bad weather?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rain or shine. For severe weather, we move the party to Lemonade Disco land venue."
      }
    },
    {
      "@type": "Question",
      "name": "What's the alcohol policy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BYOB for 21+; cans/plastic only; coolers with ice and cups provided."
      }
    },
    {
      "@type": "Question",
      "name": "When do we get photos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Professional photos delivered digitally within 2–3 weeks after your cruise."
      }
    },
    {
      "@type": "Question",
      "name": "Where do we meet?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Anderson Mill Marina, 13993 FM 2769, Leander, TX 78641. Arrive 15–20 minutes early; free parking available."
      }
    },
    {
      "@type": "Question",
      "name": "How many people can join?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Disco cruises handle 20-40+ guests per group, up to 100 total capacity."
      }
    },
    {
      "@type": "Question",
      "name": "Can we bring food?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, bring your own or we can coordinate delivery right to the boat."
      }
    },
    {
      "@type": "Question",
      "name": "Is swimming allowed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, when conditions are safe at captain's discretion. Life jackets are on board and available for swimming - we encourage guests to wear them for safety."
      }
    }
  ]
}
