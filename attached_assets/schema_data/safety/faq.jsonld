{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is Premier Party Cruises' safety record?", "acceptedAnswer": { "@type": "Answer", "text": "15+ years operating on Lake Travis, 150,000+ guests served, perfect safety record. All captains are licensed with extensive Lake Travis experience. All vessels are regularly inspected and carry current liability insurance. Certificates of Insurance are available for corporate clients on request." } },
    { "@type": "Question", "name": "Are Premier Party Cruises captains licensed?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — every captain holds a current state-issued Master or OUPV license, has completed CPR and first aid certification, and has multi-year Lake Travis operational experience. No unlicensed deckhands drive the boat." } },
    { "@type": "Question", "name": "What safety equipment is on every Premier Party Cruises boat?", "acceptedAnswer": { "@type": "Answer", "text": "USCG-approved life jackets (adult sizing for every guest), fire extinguishers, marine-grade first aid kit, VHF marine radio, navigation lights, throwable flotation devices, and emergency signaling equipment. Every boat is inspected before each cruise by the captain." } },
    { "@type": "Question", "name": "What happens if the weather is bad on our cruise day?", "acceptedAnswer": { "@type": "Answer", "text": "Captain makes the final call based on real-time weather, wind, and lake conditions. If conditions are unsafe (lightning within 10 miles, sustained winds over 25 mph, severe weather warning), we reschedule to a different date at no cost, or issue a full refund. Light rain does not stop the cruise." } },
    { "@type": "Question", "name": "Can non-swimmers come on a Lake Travis party boat?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — the boat is a stable platform, and swimming is always optional. Life jackets are available for every guest on board. We recommend non-swimmers wear a life jacket throughout the cruise and stay on the boat during swim stops." } },
    { "@type": "Question", "name": "Are children allowed on Premier Party Cruises?", "acceptedAnswer": { "@type": "Answer", "text": "On private charters, yes — children are welcome with a supervising adult. The ATX Disco Cruise (public multi-group Fri/Sat cruise) is 21+ only because of the bach party format and alcohol environment. Children under 13 on private charters must wear a USCG-approved life jacket at all times while on deck." } },
    { "@type": "Question", "name": "What is the alcohol policy on Premier Party Cruises boats?", "acceptedAnswer": { "@type": "Answer", "text": "All boats are BYOB. Cans and plastic only — no glass of any kind. The captain has full authority to refuse boarding or cut off over-served guests. Over-consumption jeopardizes the safety record we've protected for 15+ years, so we enforce responsibly." } }
  ]
}
