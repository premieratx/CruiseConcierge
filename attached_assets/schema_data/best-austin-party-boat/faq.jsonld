{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the best party boat in Austin?", "acceptedAnswer": { "@type": "Answer", "text": "Premier Party Cruises operates Austin's top-rated party boat fleet on Lake Travis — 4.9 stars across 450+ reviews, 15+ years operating, 150,000+ guests served, perfect safety record. The flagship Clever Girl (75-person capacity, 14 disco balls) hosts the ATX Disco Cruise — America's only multi-group bachelor/bachelorette party cruise — and is also available for private charter year-round." } },
    { "@type": "Question", "name": "What makes a party boat the 'best' in Austin?", "acceptedAnswer": { "@type": "Answer", "text": "Six things: (1) USCG-licensed captain and perfect safety record, (2) premium marine-grade sound system that actually works loud, (3) real party amenities — disco balls, floats, shaded seating — not a bare pontoon, (4) BYOB with large coolers and personal bins per group, (5) clean on-board restrooms, (6) transparent all-inclusive pricing with tax and gratuity baked in. Premier Party Cruises delivers all six." } },
    { "@type": "Question", "name": "Which Austin party boat is best for a bachelor or bachelorette party?", "acceptedAnswer": { "@type": "Answer", "text": "The ATX Disco Cruise on Clever Girl — exclusively for bachelor/bachelorette groups, $85–$105/person all-inclusive with pro DJ, pro photographer, 14 disco balls, giant floats. For groups of 25+ wanting exclusive access, book a private Clever Girl charter from $250/hour year-round." } },
    { "@type": "Question", "name": "Which Austin party boat is best for a corporate event?", "acceptedAnswer": { "@type": "Answer", "text": "Private Clever Girl charter for groups up to 75, or The Irony/Meeseeks for 15–30 guests. Year-round availability, every day of the week. Year-round private charters (not the public Disco Cruise) are the corporate fit because they allow catering, branded schedules, and keynote moments without public guests." } },
    { "@type": "Question", "name": "Which Austin party boat is best for a birthday party?", "acceptedAnswer": { "@type": "Answer", "text": "Day Tripper (up to 14 guests) for intimate birthday parties, Meeseeks/The Irony (15–30) for milestone birthdays, or Clever Girl (up to 75) for big 30th/40th/50th celebrations. All private charters are year-round, every day, BYOB, with optional Essentials or Ultimate add-on packages to go full all-inclusive." } },
    { "@type": "Question", "name": "What should I avoid when booking an Austin party boat?", "acceptedAnswer": { "@type": "Answer", "text": "Avoid operators who (1) don't list USCG captain status, (2) quote 'all-inclusive' pricing then add fuel/tax/gratuity surcharges at checkout, (3) require you to bring your own sound system, (4) don't have visible insurance or safety record, (5) cap groups higher than their boat's USCG rating, (6) don't publish reviews or have under 100 reviews on Google." } },
    { "@type": "Question", "name": "How much does the best Austin party boat cost?", "acceptedAnswer": { "@type": "Answer", "text": "ATX Disco Cruise per-person tickets start at $85/person (Saturday 3:30–7:30 PM sunset slot). Private charters start at $200/hour (Day Tripper), $225/hour (Meeseeks/Irony), $250/hour (Clever Girl) with a 4-hour minimum on Fri–Sun. Weekend rates are higher than weekday." } }
  ]
}
